# ===== 必須: AWS認証 =====

# AWSプロファイル名（setup_windows.bat で設定済み）
AWS_PROFILE=chatwork-webhook

# ===== 必須: グローバル接続情報 =====

# SQS キューURL
SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/XXXXXXXXXXXX/chatwork-webhook-queue

# エラー報告用（エラー報告アカウント）
CHATWORK_API_TOKEN_ERROR_REPORTER=YOUR_ERROR_REPORTER_TOKEN
CHATWORK_ERROR_ROOM_ID=YOUR_ROOM_ID(xxxxxxxxx)

# ===== オプション: メンテナンス =====
# MAINTENANCE_ROOM_ID=YOUR_ROOM_ID(xxxxxxxxx)

# ===== オプション: AI呼び出し方式 =====
# 1=Anthropic API直接呼び出し（高速・推奨）, 0=Claude Code CLI（従来方式）
USE_DIRECT_API=1

# Anthropic API キー（USE_DIRECT_API=1 の場合に必須）
# https://console.anthropic.com/ で発行
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ===== オプション: Claude モデル =====
# claude-haiku-4-5  : 最速・低コスト（デフォルト）
# claude-sonnet-4-6 : バランス型
# claude-opus-4-6   : 最高性能・高コスト
CLAUDE_MODEL=claude-haiku-4-5

# ===== オプション: Claude Code パス（USE_DIRECT_API=0 の場合のみ使用） =====
# CLAUDE_COMMAND=C:\Users\ユーザー名\.claude\local\claude.exe

# ===== オプション: 動作パラメータ =====
# SQSポーリング方式: 0=ショートポーリング（デフォルト）, 1-20=ロングポーリング（秒）
# ロングポーリングはSQSコスト削減に有効。通常は20を推奨。
# ロングポーリング時は POLL_INTERVAL は無効（Waitが代わりのインターバルになる）
SQS_WAIT_TIME_SECONDS=1
POLL_INTERVAL=0.5
CLAUDE_TIMEOUT=60
FOLLOWUP_WAIT_SECONDS=30
MAX_AI_CONVERSATION_TURNS=10
REPLY_COOLDOWN_SECONDS=15

# ===== オプション: Google Workspace API =====
# サービスアカウントの JSON キーファイルのパス
# Google Cloud Console で作成: https://console.cloud.google.com/iam-admin/serviceaccounts
# Drive / Sheets / Gmail 等の API を有効化し、キーを発行してパスを指定
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=C:\path\to\service-account.json

# ===== メンバー固有設定は各メンバーフォルダの member.env に記載 =====
# 例: members/01_yamada/member.env
# 詳細は members/templates/member.env.example を参照
